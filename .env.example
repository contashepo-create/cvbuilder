# Supabase Configuration
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Telegram Bot (for payment notifications + 2FA + security alerts)
VITE_TELEGRAM_BOT_TOKEN=your-bot-token-here
VITE_TELEGRAM_ADMIN_CHAT_ID=your-chat-id-here

# Admin panel (use random strings in production)
VITE_ADMIN_PATH=your-secret-admin-path
VITE_ADMIN_KEY=your-secret-admin-key

# Cloudflare Turnstile (free captcha — get from cloudflare dashboard)
VITE_TURNSTILE_SITE_KEY=your-turnstile-site-key
